# ===========================================
# CampusFit Environment Configuration
# Copy to .env and fill in values
# ===========================================

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=campusfit
DB_USER=campusfit
DB_PASSWORD=change_me_in_production

# Application
APP_PORT=8080
APP_ENCRYPTION_KEY=  # REQUIRED: Generate with: openssl rand -hex 32
APP_SESSION_TIMEOUT_MINUTES=30
APP_LOCKOUT_ATTEMPTS=5
APP_LOCKOUT_DURATION_MINUTES=15

# Notification channels (all disabled by default for offline/local mode)
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_WECOM_ENABLED=false

# Export / Retention
EXPORT_RETENTION_DAYS=30

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
VITE_MOCK_MODE=false
